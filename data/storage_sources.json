{
  "_comment": "Cleanup target catalog for the storage module. Each source: name, description, path (env vars expanded at runtime), filter (glob), minAgeDays (skip files newer than N days so active work isn't nuked), riskLevel (auto = delete without asking, ask = confirm because it's big or holds recoverable data, skip_if_unused_apps_ran = another module already used this), reclaimEstimate (rough MB, 0 = unknown until diagnose scans it).",
  "sources": [
    {
      "name": "user_temp",
      "description": "Per-user %TEMP% — installer leftovers, half-decompressed archives, IDE caches.",
      "path": "%TEMP%",
      "filter": "*",
      "minAgeDays": 1,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "local_appdata_temp",
      "description": "AppData\\Local\\Temp — same purpose as %TEMP%, often a duplicate location.",
      "path": "%LOCALAPPDATA%\\Temp",
      "filter": "*",
      "minAgeDays": 1,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "windows_temp",
      "description": "System-wide C:\\Windows\\Temp — service and installer scratch.",
      "path": "%WINDIR%\\Temp",
      "filter": "*",
      "minAgeDays": 1,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "windows_update_cache",
      "description": "Windows Update download cache (SoftwareDistribution\\Download).",
      "path": "%WINDIR%\\SoftwareDistribution\\Download",
      "filter": "*",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Stop wuauserv before purging, restart after."
    },
    {
      "name": "delivery_optimization_cache",
      "description": "Delivery Optimization P2P update chunks.",
      "path": "%WINDIR%\\SoftwareDistribution\\DeliveryOptimization\\Cache",
      "filter": "*",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Prefer 'Delete-DeliveryOptimizationCache' cmdlet on Win11 if available."
    },
    {
      "name": "recycle_bin",
      "description": "System-wide recycle bin (all drives).",
      "path": "C:\\$Recycle.Bin",
      "filter": "*",
      "minAgeDays": 0,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Use Clear-RecycleBin -Force cmdlet, not direct delete. Ask user — may hold recoverable files."
    },
    {
      "name": "windows_old",
      "description": "C:\\Windows.old — previous OS install after a feature update / upgrade.",
      "path": "C:\\Windows.old",
      "filter": "*",
      "minAgeDays": 0,
      "riskLevel": "ask",
      "reclaimEstimate": 20000,
      "notes": "Can be 15-40 GB. Deletion is one-way — after this the 10-day rollback is gone."
    },
    {
      "name": "thumbnail_cache",
      "description": "Explorer thumbnail cache DBs — regenerated on demand.",
      "path": "%LOCALAPPDATA%\\Microsoft\\Windows\\Explorer",
      "filter": "thumbcache_*.db",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Stop Explorer first, or the DBs are locked."
    },
    {
      "name": "iconcache",
      "description": "Explorer icon cache DBs — regenerated on demand.",
      "path": "%LOCALAPPDATA%\\Microsoft\\Windows\\Explorer",
      "filter": "iconcache_*.db",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "crash_dumps_user",
      "description": "Per-user CrashDumps folder.",
      "path": "%LOCALAPPDATA%\\CrashDumps",
      "filter": "*.dmp",
      "minAgeDays": 7,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Ask if crashdumps module hasn't run yet — the dumps may be useful for diagnosis."
    },
    {
      "name": "minidumps",
      "description": "Kernel minidumps.",
      "path": "%WINDIR%\\Minidump",
      "filter": "*.dmp",
      "minAgeDays": 30,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Same as crash_dumps_user — coordinate with crashdumps module."
    },
    {
      "name": "memory_dump",
      "description": "Full/kernel memory dump (MEMORY.DMP) from a BSOD.",
      "path": "%WINDIR%\\MEMORY.DMP",
      "filter": "MEMORY.DMP",
      "minAgeDays": 30,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Can be several GB. Ask before deleting."
    },
    {
      "name": "prefetch",
      "description": "Windows Prefetch — used by SysMain to speed app launches.",
      "path": "%WINDIR%\\Prefetch",
      "filter": "*.pf",
      "minAgeDays": 90,
      "riskLevel": "skip_if_unused_apps_ran",
      "reclaimEstimate": 0,
      "notes": "The unused-apps module reads Prefetch to detect unlaunched apps. If that module ran this session, leave Prefetch alone."
    },
    {
      "name": "font_cache",
      "description": "Windows Font cache — regenerated by FontCache service.",
      "path": "%WINDIR%\\ServiceProfiles\\LocalService\\AppData\\Local\\FontCache",
      "filter": "*.dat",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Stop FontCache service before deleting."
    },
    {
      "name": "logs_wer",
      "description": "Windows Error Reporting queued/archived reports.",
      "path": "%PROGRAMDATA%\\Microsoft\\Windows\\WER",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "logs_cbs",
      "description": "Component-Based Servicing logs (grow after every DISM/SFC run).",
      "path": "%WINDIR%\\Logs\\CBS",
      "filter": "*.log",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "logs_dism",
      "description": "DISM logs.",
      "path": "%WINDIR%\\Logs\\DISM",
      "filter": "*.log",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "edge_cache",
      "description": "Microsoft Edge web cache — regenerated on use.",
      "path": "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\Cache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Ask — user may have offline cached content."
    },
    {
      "name": "chrome_cache",
      "description": "Google Chrome web cache — regenerated on use.",
      "path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\Cache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "ask",
      "reclaimEstimate": 0
    },
    {
      "name": "dism_component_cleanup",
      "description": "Not a directory — invoke DISM /Online /Cleanup-Image /StartComponentCleanup /ResetBase to shrink WinSxS.",
      "path": "COMMAND:DISM /Online /Cleanup-Image /StartComponentCleanup /ResetBase",
      "filter": "",
      "minAgeDays": 0,
      "riskLevel": "ask",
      "reclaimEstimate": 3000,
      "notes": "ResetBase is one-way — cannot uninstall installed superseded Windows Updates afterward. Ask user."
    },
    {
      "name": "chrome_code_cache",
      "description": "Chrome Code Cache (JavaScript compiled code) - regenerated on use.",
      "path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\Code Cache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "chrome_gpu_cache",
      "description": "Chrome GPU shader cache.",
      "path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\GPUCache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "chrome_media_cache",
      "description": "Chrome Media Cache (video/audio streams).",
      "path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\Media Cache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "chrome_service_worker_cache",
      "description": "Chrome Service Worker cache (PWAs).",
      "path": "%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\Service Worker\\CacheStorage",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "firefox_cache",
      "description": "Firefox web cache across all profiles.",
      "path": "%LOCALAPPDATA%\\Mozilla\\Firefox\\Profiles",
      "filter": "cache2",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Iterate profiles/*/cache2 rather than one path."
    },
    {
      "name": "discord_cache",
      "description": "Discord message + media cache.",
      "path": "%APPDATA%\\discord\\Cache",
      "filter": "*",
      "minAgeDays": 7,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "discord_code_cache",
      "description": "Discord Code Cache.",
      "path": "%APPDATA%\\discord\\Code Cache",
      "filter": "*",
      "minAgeDays": 7,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "discord_gpu_cache",
      "description": "Discord GPU Cache.",
      "path": "%APPDATA%\\discord\\GPUCache",
      "filter": "*",
      "minAgeDays": 7,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "slack_cache",
      "description": "Slack message + media cache.",
      "path": "%APPDATA%\\Slack\\Cache",
      "filter": "*",
      "minAgeDays": 7,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "slack_code_cache",
      "description": "Slack Code Cache.",
      "path": "%APPDATA%\\Slack\\Code Cache",
      "filter": "*",
      "minAgeDays": 7,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "zoom_logs",
      "description": "Zoom logs and diagnostic files.",
      "path": "%APPDATA%\\Zoom\\logs",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "teams_new_cache",
      "description": "Microsoft Teams (new / Store) cache.",
      "path": "%LOCALAPPDATA%\\Packages\\MSTeams_8wekyb3d8bbwe\\LocalCache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "teams_classic_cache",
      "description": "Microsoft Teams (classic) cache.",
      "path": "%APPDATA%\\Microsoft\\Teams\\Cache",
      "filter": "*",
      "minAgeDays": 14,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "spotify_data",
      "description": "Spotify local cached tracks + playlist metadata.",
      "path": "%LOCALAPPDATA%\\Spotify\\Data",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Ask — if user uses Spotify offline downloads, this may include them."
    },
    {
      "name": "vscode_cache",
      "description": "Visual Studio Code cache + extension host cache.",
      "path": "%APPDATA%\\Code\\Cache",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "vscode_cached_data",
      "description": "VS Code CachedData (bytecode caches).",
      "path": "%APPDATA%\\Code\\CachedData",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "cursor_cache",
      "description": "Cursor editor cache.",
      "path": "%APPDATA%\\Cursor\\Cache",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "notion_cache",
      "description": "Notion desktop cache.",
      "path": "%APPDATA%\\Notion\\Cache",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "adobe_media_cache",
      "description": "Adobe Common Media Cache — grows large with Premiere/After Effects use.",
      "path": "%APPDATA%\\Adobe\\Common\\Media Cache",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "ask",
      "reclaimEstimate": 0,
      "notes": "Ask — Adobe rebuilds these when you re-open projects."
    },
    {
      "name": "adobe_media_cache_files",
      "description": "Adobe Common Media Cache Files.",
      "path": "%APPDATA%\\Adobe\\Common\\Media Cache Files",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "ask",
      "reclaimEstimate": 0
    },
    {
      "name": "onedrive_iconcache",
      "description": "OneDrive icon overlay cache.",
      "path": "%LOCALAPPDATA%\\Microsoft\\OneDrive\\IconCache",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "windows_update_leftover_bt",
      "description": "Leftover from a failed / interrupted Windows Update ($Windows.~BT).",
      "path": "C:\\$Windows.~BT",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "windows_update_leftover_ws",
      "description": "Leftover from Windows Setup ($Windows.~WS).",
      "path": "C:\\$Windows.~WS",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "defender_scan_history",
      "description": "Windows Defender scan history.",
      "path": "%PROGRAMDATA%\\Microsoft\\Windows Defender\\Scans\\History",
      "filter": "*",
      "minAgeDays": 30,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "Stops MpKslDrv briefly but harmless."
    },
    {
      "name": "dns_cache_flush",
      "description": "Flush DNS resolver cache.",
      "path": "COMMAND:ipconfig /flushdns",
      "filter": "",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0
    },
    {
      "name": "windows_store_cache",
      "description": "Reset Windows Store cache.",
      "path": "COMMAND:wsreset.exe -i",
      "filter": "",
      "minAgeDays": 0,
      "riskLevel": "auto",
      "reclaimEstimate": 0,
      "notes": "wsreset.exe with -i is silent."
    }
  ]
}
