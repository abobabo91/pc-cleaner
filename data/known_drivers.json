{
  "_comment": "Mapping of .sys driver filenames to their owner (vendor) and product family. Used by the crashdumps module to make !analyze -v output human-readable and to route stale-driver findings to the right OEM catalog (drivers module). driverFile keys align with known_bad_drivers.json entries where applicable.",
  "_matchRule": "Match on exact filename (case-insensitive). ntoskrnl.exe is always co-blamed by !analyze — treat as noise unless it's the ONLY blame with no other .sys in the stack.",
  "drivers": {
    "rtwlane.sys":     { "owner": "Realtek", "product": "Realtek Wi-Fi 5 miniport (RTL8822CE / RTL8821CE)", "category": "wlan" },
    "rtwlanu.sys":     { "owner": "Realtek", "product": "Realtek Wi-Fi USB miniport", "category": "wlan" },
    "rtwlane6.sys":    { "owner": "Realtek", "product": "Realtek Wi-Fi 6 miniport (RTL8852AE / RTL8852BE)", "category": "wlan" },
    "amdacpbus.sys":   { "owner": "AMD", "product": "AMD Audio CoProcessor Bus (carries BT on Ryzen 6000+)", "category": "audio_bus", "note": "Crash blame here usually means combo-card WLAN/BT — see known_bad_drivers.json" },
    "amduw23g.sys":    { "owner": "AMD", "product": "AMD Radeon display driver (mobile, Windows 10/11 UMD)", "category": "gpu" },
    "amdxc32.sys":     { "owner": "AMD", "product": "AMD Radeon display driver (32-bit KMD component)", "category": "gpu" },
    "amdxc64.sys":     { "owner": "AMD", "product": "AMD Radeon display driver (64-bit KMD component)", "category": "gpu" },
    "atikmdag.sys":    { "owner": "AMD", "product": "AMD Radeon display kernel-mode (legacy name)", "category": "gpu" },
    "nvlddmkm.sys":    { "owner": "NVIDIA", "product": "NVIDIA display driver (kernel mode)", "category": "gpu" },
    "dxgmms2.sys":     { "owner": "Microsoft", "product": "DirectX kernel memory manager", "category": "os_gpu", "note": "Co-blamed with the actual GPU driver almost always" },
    "dxgkrnl.sys":     { "owner": "Microsoft", "product": "DirectX graphics kernel", "category": "os_gpu" },
    "ndis.sys":        { "owner": "Microsoft", "product": "Network Driver Interface Specification (NDIS)", "category": "os_net", "note": "Blame here usually means the miniport (rtwlane, e1r*, etc.) is the real culprit" },
    "netio.sys":       { "owner": "Microsoft", "product": "Windows network I/O subsystem", "category": "os_net" },
    "tcpip.sys":       { "owner": "Microsoft", "product": "Windows TCP/IP stack", "category": "os_net" },
    "stornvme.sys":    { "owner": "Microsoft", "product": "Windows generic NVMe driver", "category": "storage" },
    "storahci.sys":    { "owner": "Microsoft", "product": "Windows generic AHCI driver", "category": "storage" },
    "iaStorAC.sys":    { "owner": "Intel", "product": "Intel Rapid Storage Technology (RST) AHCI/NVMe", "category": "storage" },
    "iaLPSSi.sys":     { "owner": "Intel", "product": "Intel Low Power Subsystem (LPSS)", "category": "chipset" },
    "iaLPSSi_GPIO.sys":{ "owner": "Intel", "product": "Intel LPSS GPIO controller", "category": "chipset" },
    "iaLPSSi_I2C.sys": { "owner": "Intel", "product": "Intel LPSS I2C controller", "category": "chipset" },
    "iaLPSSi_UART.sys":{ "owner": "Intel", "product": "Intel LPSS UART controller", "category": "chipset" },
    "MpKslDrv.sys":    { "owner": "Microsoft", "product": "Microsoft Defender kernel-mode driver", "category": "security" },
    "WdFilter.sys":    { "owner": "Microsoft", "product": "Microsoft Defender filesystem filter", "category": "security" },
    "volmgr.sys":      { "owner": "Microsoft", "product": "Windows Volume Manager", "category": "storage_os", "note": "volmgr Event ID 161 in the log usually indicates a Modern Standby wake failure, not a real BSOD" },
    "ntoskrnl.exe":    { "owner": "Microsoft", "product": "Windows kernel", "category": "os_kernel", "note": "Always co-blamed — treat as noise unless it's the sole blame" },
    "hal.dll":         { "owner": "Microsoft", "product": "Windows Hardware Abstraction Layer", "category": "os_kernel" },
    "usbhub.sys":      { "owner": "Microsoft", "product": "USB hub driver", "category": "usb" },
    "usbhub3.sys":     { "owner": "Microsoft", "product": "USB 3.0 hub driver", "category": "usb" },
    "USBXHCI.sys":     { "owner": "Microsoft", "product": "USB xHCI host controller", "category": "usb" },
    "bthusb.sys":      { "owner": "Microsoft", "product": "Bluetooth USB transport (generic)", "category": "bluetooth", "note": "If BT is served by bthusb (Microsoft generic) rather than a Realtek/Intel BT driver, the chip firmware patch is missing — expect degraded range" },
    "bthport.sys":     { "owner": "Microsoft", "product": "Bluetooth port driver", "category": "bluetooth" }
  }
}
